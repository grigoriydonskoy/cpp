#include <iostream>
using namespace std;

int main() {
    
    int a = 8;           
    double b = 5.5;      
    float c = 2.3f;     
    char d = '5';    
    
    cout << "Арифметические операции:" << endl;
    cout << "a + b = " << a + b << endl;
    cout << "b - c = " << b - c << endl;
    cout << "a * c = " << a * c << endl;
    cout << "b / a = " << b / a << endl;
    cout << "d - a = " << d - a << endl;
    
    return 0;
}
