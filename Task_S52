#include <iostream>
using namespace std;

void print(int a) {
    cout << "int: " << a << endl;
}

void print(float a) {
    cout << "float: " << a << endl;
}

void print(char a) {
    cout << "char: " << a << endl;
}

void print(int a, int b) {
    cout << "int и int: " << a << ", " << b << endl;
}

int main() {
    print(42);
    print(3.14159f);
    print('Z');
    print(100, 200);
    
    return 0;
}
