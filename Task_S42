#include <iostream>
#include <algorithm>
using namespace std;
void mySort(int arr[], int size) {

    sort(arr, arr + size, greater<int>());
}

int main() {
    int numbers[10] = {5, 2, 8, 1, 9, 3, 7, 4, 6, 0};
    
    mySort(numbers, 10); 
    
    for (int i = 0; i < 10; i++) {
        cout << numbers[i] << " ";
    }
    
    return 0;
}
