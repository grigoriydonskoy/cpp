#include <iostream>
#include <cstring>
using namespace std;

int main() {
    char str[100];
    
    cout << "Введите строку: ";
    cin.getline(str, 100);
    
    for (int i = 0; i < strlen(str); i++) {
        if (str[i] >= 'a' && str[i] <= 'z')
            str[i] = ((str[i] - 'a' + 1) % 26) + 'a';
        else if (str[i] >= 'A' && str[i] <= 'Z')
            str[i] = ((str[i] - 'A' + 1) % 26) + 'A';
    }
    
    cout << "Результат: " << str << endl;
    
    return 0;
}
