#include <iostream>
#include <cstring>
using namespace std;

int main() {
    char str[100];
    char *ptr;
    
    cout << "Введите строку: ";
    cin.getline(str, 100);
    
    ptr = str;
    
    
    for (int i = 0; i < strlen(str); i++) {
        if (*(ptr + i) >= 'a' && *(ptr + i) <= 'z')
            *(ptr + i) = ((*(ptr + i) - 'a' + 1) % 26) + 'a';
        else if (*(ptr + i) >= 'A' && *(ptr + i) <= 'Z')
            *(ptr + i) = ((*(ptr + i) - 'A' + 1) % 26) + 'A';
    }
    
    cout << "Результат: " << str << endl;
    
    return 0;
}
