#include <iostream>
#include <string>
using namespace std;

void reverse(string str) {

    for (int i = str.length() - 1; i >= 0; i--) {
        cout << str[i];
    }
}

int main() {
    string text = "Hello man!";
    
    cout << "Было: " << text << endl;
    cout << "Стало: ";
    reverse(text);
    
    return 0;
}
