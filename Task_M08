#include <iostream>
#include <math.h>
using namespace std;

double get_angle(double a, double b, double c) {
    if (a <= 0 || b <= 0 || c <= 0) 
        return -1;
    if (a + b <= c || a + c <= b || b + c <= a) 
        return -1;
    
    double cosA = (b * b + c * c - a * a) / (2 * b * c);
    if (cosA < -1) 
        cosA = -1;
    if (cosA > 1) 
        cosA = 1;
    
    return acos(cosA) * 180 / M_PI;
}

int main() {
    double a, b, c;
    
    cout << "Введите три стороны треугольника: ";
    cin >> a >> b >> c;
    
    double angle = get_angle(a, b, c);
    
    if (angle == -1)
        cout << "Ошибка: некорректные стороны треугольника" << endl;
    else
        cout << "Угол напротив первой стороны: " << angle << " градусов" << endl;
    
    return 0;
}
